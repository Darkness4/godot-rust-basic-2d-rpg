[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://../rust/target/debug/libbasic_2d_rpg.so"
linux.release.x86_64 =   "res://../rust/target/release/libbasic_2d_rpg.so"
windows.debug.x86_64 =   "res://../rust/target/debug/basic_2d_rpg.dll"
windows.release.x86_64 = "res://../rust/target/release/basic_2d_rpg.dll"
macos.debug =            "res://../rust/target/debug/libbasic_2d_rpg.dylib"
macos.release =          "res://../rust/target/release/libbasic_2d_rpg.dylib"
macos.debug.arm64 =      "res://../rust/target/debug/libbasic_2d_rpg.dylib"
macos.release.arm64 =    "res://../rust/target/release/libbasic_2d_rpg.dylib"
